# Copy this file to .env and fill in your values.

# --- Choose ONE provider ---

# Option A: OpenAI
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
MODEL_NAME=gpt-4o-mini
EMBED_MODEL_NAME=text-embedding-3-small

# Option B: Groq (free tier, very fast — great for live demos)
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=llama-3.3-70b-versatile
# NOTE: Groq does not currently serve embeddings, so RAG (the /api/documents
#       endpoint) requires an OpenAI key for EMBED_MODEL_NAME even if chat
#       uses Groq. You can mix providers by hardcoding a second client in
#       app.py if needed.

# Option C: Gemini (free tier via Google AI Studio, OpenAI-compatible endpoint
# — also makes you eligible for Gemini sponsor tracks at most hackathons)
# OPENAI_API_KEY=AIza...
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# MODEL_NAME=gemini-2.0-flash

# --- CoachCam Pro: coaching assistant tuned to reference your training plan ---
SYSTEM_PROMPT="You are a coach assistant. The user will describe their joint-angle data from a tracked exercise. Compare it to the relevant section of their training plan (provided as context) and give 2-3 sentences of specific feedback — reference the plan's actual targets by name and number. End with one concrete thing to focus on for the next set."
